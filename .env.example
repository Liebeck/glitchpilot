# GlitchTip
GLITCHTIP_URL=https://your-glitchtip-instance.example.com
GLITCHTIP_TOKEN=your-api-token-here
GLITCHTIP_ORG=your-org-slug

# Azure OpenAI
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_KEY=your-azure-openai-key
OPENAI_MODEL=gpt-4o

# GitHub
GITHUB_TOKEN=ghp_your-classic-pat-with-repo-scope
GITHUB_LABELS=glitchpilot
GITHUB_AGENT_LABEL=copilot
GITHUB_ASSIGN_TO=
GITHUB_COPILOT_MODEL=

# SMTP / Mail
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM=glitchpilot@example.com
MAIL_RECIPIENTS=dev-team@example.com

# Projects (JSON array)
PROJECTS='[{"slug":"my-project","targetEnvironment":"Production","gitHubOwner":"your-org","gitHubRepo":"your-repo"}]'

# Filters / Tuning
MIN_OCCURRENCES=1
LOOKBACK_HOURS=24
EXCLUDE_TITLES=
EXCLUDE_IDS=

# Azure Function (only needed for GlitchPilot.Functions)
# TRIAGE_SCHEDULE=0 0 5 * * *
